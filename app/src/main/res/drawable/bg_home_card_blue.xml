<?xml version="1.0" encoding="utf-8"?>
<!-- 首页"歌名"卡片: 蓝紫渐变(对应设计图喇叭图标的蓝紫卡) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:startColor="#FF3B7CFF"
                android:centerColor="#FF2050CC"
                android:endColor="#FF0F2D80"
                android:type="linear" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item android:left="0dp" android:gravity="right|bottom">
        <shape android:shape="rectangle">
            <size android:width="120dp" android:height="120dp" />
            <gradient
                android:angle="135"
                android:startColor="#33FFFFFF"
                android:centerColor="#11FFFFFF"
                android:endColor="#00000000"
                android:type="linear" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</layer-list>
