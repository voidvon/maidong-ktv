    <!-- 媒体通知文本外观存根:继承 AppCompat 提供的基础通知文本外观。
         原本由 androidx.media:media 库提供,此处补齐以使通知模板布局可编译。 -->
    <style name="TextAppearance.Compat.Notification.Media" parent="TextAppearance.Compat.Notification" />
    <style name="TextAppearance.Compat.Notification.Title.Media" parent="TextAppearance.Compat.Notification.Title" />
    <style name="TextAppearance.Compat.Notification.Line2.Media" parent="TextAppearance.Compat.Notification.Line2" />
    <style name="TextAppearance.Compat.Notification.Time.Media" parent="TextAppearance.Compat.Notification.Time" />
    <style name="TextAppearance.Compat.Notification.Info.Media" parent="TextAppearance.Compat.Notification.Info" />
</resources>
