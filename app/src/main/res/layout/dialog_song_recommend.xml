<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ott_bg_dialog">

    <ImageView
        android:id="@+id/image_recommend_cover"
        android:layout_width="match_parent"
        android:layout_height="93dp"
        android:scaleType="fitXY"
        android:src="@drawable/cover_dialog_song_recommend" />

    <ImageView
        android:id="@+id/image_recommend_close"
        android:layout_width="51dp"
        android:layout_height="51dp"
        android:layout_gravity="top|end"
        android:padding="12dp"
        android:src="@drawable/ott_ic_recommend_close" />

    <GridLayout
        android:id="@+id/recommend_song_grid"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="103dp"
        android:layout_marginBottom="60dp"
        android:alignmentMode="alignMargins"
        android:columnCount="2"
        android:rowCount="5" />

    <TextView
        android:id="@+id/button_recommend_confirm"
        android:layout_width="wrap_content"
        android:layout_height="43dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_recommend_confirm"
        android:gravity="center"
        android:minWidth="150dp"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:text="一键点歌(0首)"
        android:textColor="#FFFFFFFF"
        android:textSize="16sp" />
</FrameLayout>
