<?xml version="1.0" encoding="utf-8"?>
<!--
  调音/音频控制弹窗(对应"弹窗-调音.jpg")
  包含:
    - 4 个开关按钮:立体声/伴唱/原唱/静音
    - 2 个滑块:麦克风(音量+效果)、音乐音量
    - 关闭按钮
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="640dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_panel"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- 标题 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎚  调音设置"
            android:textColor="#FF27CCA4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_audio_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_btn_dialog_close"
            android:gravity="center"
            android:text="×"
            android:textColor="#FFCCCCCC"
            android:textSize="22sp" />
    </LinearLayout>

    <!-- 4 个开关按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp"
        android:weightSum="4">

        <TextView
            android:id="@+id/btn_tone_stereo"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_toggle_on"
            android:gravity="center"
            android:text="🔊 立体声"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_tone_accomp"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_toggle_off"
            android:gravity="center"
            android:text="🎤 伴唱"
            android:textColor="#FFCCCCCC"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_tone_origin"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_toggle_on"
            android:gravity="center"
            android:text="🎙 原唱"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_tone_mute"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_toggle_off"
            android:gravity="center"
            android:text="🔇 静音"
            android:textColor="#FFCCCCCC"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 麦克风 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="麦克风音量"
        android:textColor="#FFE0E0FF"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <SeekBar
            android:id="@+id/seek_mic_volume"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="60"
            android:progressTint="#FF27CCA4"
            android:thumbTint="#FF27CCA4" />

        <TextView
            android:id="@+id/text_mic_volume_value"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="60"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="麦克风效果"
        android:textColor="#FFE0E0FF"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <SeekBar
            android:id="@+id/seek_mic_effect"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="50"
            android:progressTint="#FF27CCA4"
            android:thumbTint="#FF27CCA4" />

        <TextView
            android:id="@+id/text_mic_effect_value"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="50"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 音乐音量 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="音乐音量"
        android:textColor="#FFE0E0FF"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <SeekBar
            android:id="@+id/seek_music_volume"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="80"
            android:progressTint="#FF27CCA4"
            android:thumbTint="#FF27CCA4" />

        <TextView
            android:id="@+id/text_music_volume_value"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="80"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 底部按钮行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_audio_default"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_btn_glass"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="恢复默认"
            android:textColor="#FFCCCCCC"
            android:textSize="13sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btn_audio_save"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_btn_save"
            android:gravity="center"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:text="保存"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
